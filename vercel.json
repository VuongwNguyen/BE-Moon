{
  "version": 2,
  "builds": [
    {
      "src": "public/**",
      "use": "@vercel/static"
    },
    {
      "src": "index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/auth/(.+\\.[a-zA-Z0-9]+)",
      "dest": "/public/auth/$1"
    },
    {
      "src": "/portal/(.+\\.[a-zA-Z0-9]+)",
      "dest": "/public/portal/$1"
    },
    {
      "src": "/admin/(.+\\.[a-zA-Z0-9]+)",
      "dest": "/public/admin/$1"
    },
    {
      "src": "/auth/?$",
      "dest": "/public/auth/index.html"
    },
    {
      "src": "/portal/?$",
      "dest": "/public/portal/index.html"
    },
    {
      "src": "/admin/?$",
      "dest": "/public/admin/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "index.js"
    }
  ]
}
