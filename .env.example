# ════════════════════════════════════════════════════
#  Lumora BE-Moon — Environment Variables
#  Copy file này thành .env rồi điền giá trị thực
#  $ cp .env.example .env
# ════════════════════════════════════════════════════

# ── Server ────────────────────────────────────────────
# Cổng server (mặc định 3030 nếu không đặt)
PORT=3030

# "development" → tắt rate limit, in stack trace
# "production"  → bật rate limit, ẩn lỗi chi tiết
NODE_ENV=development

# Danh sách origin được phép gọi API (CORS).
# Để trống = cho phép tất cả (chỉ dùng khi dev).
# Production: điền đúng domain, cách nhau bằng dấu phẩy.
# Ví dụ: https://lumora.vn,https://www.lumora.vn
ALLOWED_ORIGINS=

# Đặt true nếu server chạy sau HTTPS (bật HSTS header)
HTTPS=false

# URL công khai của app (dùng cho OG meta tags khi share link).
# BẮT BUỘC đặt đúng domain HTTPS ở production để link preview
# hiển thị đúng trên Messenger, Zalo, v.v.
# Ví dụ: https://lumora.nguyenvuongw.id.vn
APP_URL=

# ── Database ──────────────────────────────────────────
# MongoDB connection string (Atlas hoặc self-hosted)
DATABASE_URL=mongodb+srv://<user>:<password>@cluster.mongodb.net/?appName=...

# ── Auth ──────────────────────────────────────────────
# Khóa ký JWT — PHẢI đổi trước khi deploy production.
# Tạo khóa mạnh: openssl rand -hex 32
JWT_SECRET=change_this_in_production

# ── Email (Gmail) ─────────────────────────────────────
# Tài khoản Gmail dùng để gửi OTP và thông báo
GMAIL_USER=your@gmail.com

# App Password của Gmail (không phải mật khẩu đăng nhập).
# Tạo tại: https://myaccount.google.com/apppasswords
# Yêu cầu bật 2-Step Verification trên tài khoản Google.
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# ── ImageKit ──────────────────────────────────────────
# Lấy từ https://imagekit.io → Developer Options
IMAGEKIT_PRIVATE_KEY=private_...
IMAGEKIT_PUBLIC_KEY=public_...
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/<your-id>

# ── PayOS ─────────────────────────────────────────────
# Lấy từ https://payos.vn → Dashboard → API Keys
PAYOS_CLIENT_ID=
PAYOS_API_KEY=
PAYOS_CHECKSUM_KEY=

# ── SoundCloud ────────────────────────────────────────
# Đăng ký app tại https://soundcloud.com/you/apps
SOUNDCLOUD_CLIENT_ID=
SOUNDCLOUD_CLIENT_SECRET=
