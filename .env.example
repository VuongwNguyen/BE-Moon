# Database
DATABASE_URL=mongodb+srv://<user>:<pass>@cluster.mongodb.net/?appName=...

# ImageKit
IMAGEKIT_PRIVATE_KEY=private_...
IMAGEKIT_PUBLIC_KEY=public_...
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/...

# Auth
JWT_SECRET=change_this_in_production

# Email (Gmail)
GMAIL_USER=your@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# PayOS — get from https://payos.vn dashboard
PAYOS_CLIENT_ID=
PAYOS_API_KEY=
PAYOS_CHECKSUM_KEY=
# Return URLs after checkout (update to your production domain)
PAYOS_RETURN_URL=https://yourdomain.com/portal/?payment=success
PAYOS_CANCEL_URL=https://yourdomain.com/portal/?payment=cancel
